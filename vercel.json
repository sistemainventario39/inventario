{
    "services": {
      "frontend": {
        "root": "frontend/",
        "framework": "vite"
      },
      "backend": {
        "root": "backend/",
        "entrypoint": "index.js"
      }
    },
    "rewrites": [
      {
        "source": "/api/(.*)",
        "destination": { "service": "backend" }
      },
      {
        "source": "/((?!api).*)",
        "destination": { "service": "frontend" }
      }
    ]
  }